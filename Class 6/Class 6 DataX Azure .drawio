        <mxCell id="jQ3XhOnWibMsG6wDfxci-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Microsoft Azure Entra ID or AD Account&lt;/h1&gt;&lt;div&gt;It Manages your&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Users(Human Identity)&lt;/li&gt;&lt;li&gt;Groups&lt;/li&gt;&lt;li&gt;Applications&lt;/li&gt;&lt;li&gt;Service Principle&lt;/li&gt;&lt;li&gt;Authtication Tokes&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
