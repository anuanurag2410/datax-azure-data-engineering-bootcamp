        <mxCell id="jQ3XhOnWibMsG6wDfxci-18" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Question -: What is Microsoft Entra ID?&lt;/h1&gt;&lt;p&gt;Microsoft Entra ID is the Azure Identity and Access Management service that handles the authntication and authorization for users and applications across the azure resoruces&lt;/p&gt;" vertex="1">
          <mxGeometry height="100" width="480" x="70" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="jQ3XhOnWibMsG6wDfxci-19" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Question: Can someone be authenticated but not authorized?&amp;nbsp;&lt;/h1&gt;&lt;p&gt;Yes, a user can successfully login(authnticated) but may not have permissions to access a specifica resoruce(Not Authorized)&lt;/p&gt;" vertex="1">
          <mxGeometry height="100" width="810" x="70" y="1140" as="geometry" />
        </mxCell>
        <mxCell id="jQ3XhOnWibMsG6wDfxci-20" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Question: Why not use personal login for Databricks production jobs?&lt;/h1&gt;&lt;p&gt;Production jobs must run independently of human identity, Using your SP ensures controlled, auditable, non-human authentication.&lt;/p&gt;" vertex="1">
          <mxGeometry height="100" width="810" x="80" y="1260" as="geometry" />
        </mxCell>
