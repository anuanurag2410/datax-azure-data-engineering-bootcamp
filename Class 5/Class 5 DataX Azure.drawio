        <mxCell id="RcR1cv2fwgM-2c445cnW-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Flat4" vertex="1">
          <mxGeometry height="60" width="110" x="30" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="RcR1cv2fwgM-2c445cnW-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Flat5" vertex="1">
          <mxGeometry height="60" width="110" x="230" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="RcR1cv2fwgM-2c445cnW-15" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Questions -: What is the difference between RBAC and ACL?&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: x-small;&quot;&gt;&amp;nbsp;RBAC is responsible to grant the access for the storage account but ACL ensures fine-grained control within folders, allowing seperation of the access between different user groups.&lt;/span&gt;&lt;p&gt;&lt;/p&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: x-small;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: x-small;&quot;&gt;RBAC is the control access at AZURE Resources level through role assignment, while ACL control is fine-grained fie and folder-level permission inside ADLS Gen2&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="660" y="1470" as="geometry" />
        </mxCell>
        <mxCell id="RcR1cv2fwgM-2c445cnW-21" edge="1" parent="1" source="RcR1cv2fwgM-2c445cnW-16" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="RcR1cv2fwgM-2c445cnW-13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="RcR1cv2fwgM-2c445cnW-16" parent="1" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" value="BA" vertex="1">
          <mxGeometry height="60" width="30" x="-160" y="1270" as="geometry" />
        </mxCell>
        <mxCell id="RcR1cv2fwgM-2c445cnW-22" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Questions -: Why do we need ACL if RBAC exists?&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: x-small;&quot;&gt;&amp;nbsp;RBAC grants the access to the storage account, but ACL will ensure the fine-grained access control within the folders&amp;nbsp;&lt;/span&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="140" width="660" y="1660" as="geometry" />
        </mxCell>
