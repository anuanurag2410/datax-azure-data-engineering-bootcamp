          <mxGeometry height="60" width="110" x="160" y="1120" as="geometry" />
        </mxCell>
        <mxCell id="RcR1cv2fwgM-2c445cnW-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Room3" vertex="1">
          <mxGeometry height="60" width="110" x="320" y="1120" as="geometry" />
